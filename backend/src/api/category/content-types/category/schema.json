{
  "kind": "collectionType",
  "collectionName": "categories",
  "info": {
    "singularName": "category",
    "pluralName": "categories",
    "displayName": "Category",
    "description": "Product/Deal categories"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "icon": {
      "type": "string"
    },
    "description": {
      "type": "text"
    },
    "parent": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::category.category"
    },
    "stores": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::store.store",
      "inversedBy": "categories"
    },
    "coupons": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::coupon.coupon",
      "inversedBy": "categories"
    },
    "seo_title": {
      "type": "string"
    },
    "seo_description": {
      "type": "text"
    },
    "og_image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "noindex": {
      "type": "boolean",
      "default": false
    }
  }
}